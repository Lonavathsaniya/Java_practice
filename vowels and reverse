class Main {
    public static void main(String[] args) {
        String name="Saniya";
        int count=0;
        for(int i=name.length()-1;i>=0;i--){
            char ch=name.charAt(i);
            if(ch=='a'||ch=='e'||ch=='i'||ch=='o'||ch=='u'){
                System.out.println(ch+"-->vowel");
                count++;
            }
            else{
                System.out.println(ch);
            }
        }
        System.out.println("no of vowels: "+count);
    }
}
